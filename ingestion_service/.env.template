# INGEST_DB_PATH defaults to data/expenses.db (local SQLite only)
# In production (Vercel), DATABASE_URL is set automatically via Vercel Postgres — do not set INGEST_DB_PATH
INGEST_DB_PATH=data/expenses.db

# Set a strong random secret for webhook HMAC signing (run: openssl rand -hex 32)
WEBHOOK_SECRET=changeme

# Postgres connection string — set automatically by Vercel Postgres; set manually for other Postgres hosts
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# CORS allowed origins — comma-separated. Set to your Vercel frontend URL in production.
# CORS_ORIGINS=https://your-expense-tracker.vercel.app
